{
  "name": "torquest",
  "version": "1.1.0",
  "description": "Multi-source Torrent Search Engine",
  "homepage": "https://github.com/torquest/torquest",
  "author": "Torquest Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux deb",
    "build:all": "electron-builder --win --linux"
  },
  "keywords": [
    "torrent",
    "search",
    "electron"
  ],
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "webtorrent": "^2.8.5"
  },
  "build": {
    "appId": "com.torquest.app",
    "productName": "Torquest",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!android/**",
      "!*.zip"
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "icon": "icon.png",
      "maintainer": "Torquest Team",
      "vendor": "Torquest",
      "synopsis": "Multi-source Torrent Search Engine",
      "description": "Search torrents across multiple sources simultaneously",
      "mimeTypes": [
        "x-scheme-handler/magnet"
      ]
    },
    "deb": {
      "depends": [
        "gconf2",
        "gconf-service",
        "libnotify4",
        "libappindicator1",
        "libxtst6",
        "libnss3"
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    }
  }
}
