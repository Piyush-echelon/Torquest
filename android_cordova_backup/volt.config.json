{
  "name": "Torquest",
  "appId": "com.torquest.app",
  "version": "1.0.0",
  "platform": "android",
  "minSdkVersion": 22,
  "targetSdkVersion": 34,
  "orientation": "portrait",
  "permissions": [
    "INTERNET",
    "ACCESS_NETWORK_STATE"
  ],
  "build": {
    "android": {
      "releaseType": "APK",
      "architecture": ["arm64-v8a", "armeabi-v7a"]
    }
  },
  "assets": {
    "icons": "res/icon/android",
    "splash": "res/screen/android"
  }
}
